# .env 파일을 만들어 아래 값을 설정하세요 (.env는 .gitignore에 포함)

# Supabase — 구독 관리 및 고객 지원용 (금융 데이터는 전송하지 않음)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Blink API 프록시 (Deno Deploy — API 키는 서버에서 관리)
EXPO_PUBLIC_BLINK_PROXY_URL=https://your-project.deno.dev
